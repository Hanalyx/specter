{
  "name": "specter",
  "version": "0.1.0",
  "description": "A type system for specs. Validates, links, and type-checks .spec.yaml files.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "specter": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "keywords": [
    "sdd",
    "spec-driven-development",
    "specification",
    "type-system",
    "yaml",
    "validation",
    "lint",
    "cli"
  ],
  "author": "Specter Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.0",
    "graphlib": "^2.1.8",
    "semver": "^7.7.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/semver": "^7.5.0",
    "eslint": "^9.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
