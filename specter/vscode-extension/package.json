{
  "name": "specter-vscode",
  "displayName": "Specter SDD",
  "description": "Spec-Driven Development tooling for VS Code — inline coverage, diagnostics, annotation assistance, and intent drift detection.",
  "version": "0.6.7",
  "publisher": "Hanalyx",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Testing",
    "Other"
  ],
  "icon": "images/specter-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hanalyx/specter"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:**/specter.yaml",
    "workspaceContains:**/*.spec.yaml"
  ],
  "contributes": {
    "configuration": {
      "title": "Specter",
      "properties": {
        "specter.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the specter binary. If empty, Specter will search PATH then ~/.specter/bin/specter, then auto-download."
        },
        "specter.autoDownload": {
          "type": "boolean",
          "default": true,
          "description": "Automatically download the specter binary if not found."
        },
        "specter.version": {
          "type": "string",
          "default": "latest",
          "description": "Specter binary version to auto-download (e.g. '0.5.0' or 'latest')."
        },
        "specter.showInsightsOnFailure": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the Specter Insights panel when a spec fails threshold."
        }
      }
    },
    "commands": [
      {
        "command": "specter.openInsights",
        "title": "Specter: Open Insights Panel",
        "icon": "$(graph)"
      },
      {
        "command": "specter.copySpecContext",
        "title": "Specter: Copy Spec Context for AI",
        "icon": "$(clippy)"
      },
      {
        "command": "specter.runSync",
        "title": "Specter: Run Sync",
        "icon": "$(sync)"
      },
      {
        "command": "specter.revealInTree",
        "title": "Specter: Reveal in Tree View"
      },
      {
        "command": "specter.runReverse",
        "title": "Specter: Run Reverse Compiler",
        "icon": "$(database)"
      },
      {
        "command": "specter.openQuickStart",
        "title": "Specter: Open QuickStart"
      },
      {
        "command": "specter.showOutput",
        "title": "Specter: Show Output Log"
      },
      {
        "command": "specter.redownloadCli",
        "title": "Specter: Re-download CLI"
      }
    ],
    "views": {
      "specter-sidebar": [
        {
          "id": "specterCoverage",
          "name": "Coverage",
          "icon": "$(graph)",
          "contextualTitle": "Specter"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specter-sidebar",
          "title": "Specter",
          "icon": "images/specter-activity-icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "specter.runSync",
          "when": "view == specterCoverage",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "specter.copySpecContext",
          "when": "resourceExtname == .yaml",
          "group": "specter"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "specter.gettingStarted",
        "title": "Get Started with Specter",
        "description": "Zero to a working spec pipeline in minutes.",
        "steps": [
          {
            "id": "bootstrap",
            "title": "Generate draft specs",
            "description": "Generate draft specs from your code and initialize the workspace. The CLI downloads automatically.\n[Run specter reverse](command:specter.runReverse)",
            "media": {
              "markdown": "walkthrough/step1.md"
            },
            "completionEvents": [
              "onCommand:specter.runReverse"
            ]
          },
          {
            "id": "gaps",
            "title": "Close the gaps",
            "description": "Use your AI assistant to fill in acceptance criteria and validate each spec.",
            "media": {
              "markdown": "walkthrough/step2.md"
            }
          },
          {
            "id": "coverage",
            "title": "Annotate tests and run the pipeline",
            "description": "Add `@spec` and `@ac` annotations, check coverage, then lock it into CI.\n[Run specter sync](command:specter.runSync)",
            "media": {
              "markdown": "walkthrough/step3.md"
            },
            "completionEvents": [
              "onCommand:specter.runSync"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "lint": "eslint src --ext ts",
    "package": "npm run build && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
